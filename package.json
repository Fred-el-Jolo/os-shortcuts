{
  "name": "os-shortcuts",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "electrobun": "^1.15.1"
  },
  "scripts": {
    "gen:html": "bun run src/generate-html/generate.ts",
    "start": "bun run gen:html && bun run build:dev && electrobun dev",
    "build:dev": "bun install && electrobun build"
  }
}
